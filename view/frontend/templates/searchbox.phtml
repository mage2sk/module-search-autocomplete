<?php
/**
 * Panth Search Autocomplete — Luma template (vanilla JS).
 *
 * Layout pattern matches Luma's native search:
 *   - by default only a small magnifying-glass icon is visible in the
 *     header (the "trigger");
 *   - clicking the trigger opens a fixed overlay containing the search
 *     input + dropdown;
 *   - clicking outside / pressing Escape closes the overlay;
 *   - the input gets focus on open and the page does not scroll-jump.
 *
 * The actual search logic (debounce, fetch, render results, recent /
 * popular / categories / pages, keyboard nav, security) lives entirely
 * in autocomplete.js — this template just supplies the markup it hooks
 * onto.
 *
 * @var \Magento\Framework\View\Element\Template $block
 * @var \Magento\Framework\Escaper $escaper
 */
$vm = $block->getData('view_model');
if (!$vm || !$vm->isEnabled()) {
    return;
}
$jsConfig = $vm->jsConfig();
?>
<link rel="stylesheet" href="<?= $escaper->escapeUrl($block->getViewFileUrl('Panth_SearchAutocomplete::css/autocomplete.css')) ?>"/>

<!--
    Dual-mode bootstrap.

    The Panth_ThemeCustomizer module already ships its own Luma header
    icons (search trigger + bar + input). When that module is enabled
    we attach our autocomplete BEHAVIOUR to its existing input rather
    than render a parallel UI. When that module is disabled we fall
    back to the standalone trigger + overlay below — Luma stores get
    autocomplete out of the box either way.

    The attach script (attach-to-themecustomizer.js) probes for
    #panth-search-input on DOMContentLoaded; if it finds it, it hides
    the fallback wrap and wires the dropdown to that input.
-->
<script>
    window.PSAC_CONFIG = <?= /* @noEscape */ $jsConfig ?>;
    window.PSAC_CONFIG.formKey = <?= /* @noEscape */ json_encode($vm->getFormKey()) ?>;
</script>

<!-- Standalone fallback. Hidden by default — revealed by autocomplete.js
     ONLY when Panth_ThemeCustomizer's #panth-search-input is not present
     on the page (i.e. ThemeCustomizer is disabled or its header-icons
     template is not injected). Avoids the brief flash where both search
     UIs are visible at the same time. -->
<div class="psac-trigger-wrap" id="panth-search-autocomplete-luma" data-psac-fallback style="display:none">
    <button type="button"
            class="psac-trigger"
            data-psac-trigger
            aria-label="<?= $escaper->escapeHtmlAttr(__('Open search')) ?>"
            aria-expanded="false">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="7"/>
            <path d="M21 21l-4.35-4.35"/>
        </svg>
        <span class="psac-trigger-label"><?= $escaper->escapeHtml(__('Search')) ?></span>
    </button>

    <div class="psac-overlay" data-psac-overlay hidden role="dialog" aria-modal="true" aria-label="<?= $escaper->escapeHtmlAttr(__('Search')) ?>">
        <div class="psac-overlay-backdrop" data-psac-backdrop></div>
        <div class="psac-overlay-panel">
            <button type="button" class="psac-close" data-psac-close aria-label="<?= $escaper->escapeHtmlAttr(__('Close search')) ?>">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
            </button>
            <div class="psac-wrap" data-psac-config='<?= /* @noEscape */ $jsConfig ?>'>
                <form role="search" method="GET" action="<?= $escaper->escapeUrl($vm->getViewAllSearchUrl()) ?>" class="psac-form" data-psac-form>
                    <input type="hidden" name="form_key" value="<?= $escaper->escapeHtmlAttr($vm->getFormKey()) ?>"/>
                    <label class="psac-honeypot" aria-hidden="true">
                        <input type="text" name="<?= $escaper->escapeHtmlAttr($vm->getHoneypotName()) ?>" tabindex="-1" autocomplete="off" value=""/>
                    </label>
                    <input type="search"
                           name="q"
                           class="psac-input"
                           data-psac-input
                           maxlength="<?= (int) $vm->getMaxQueryLength() ?>"
                           autocomplete="off"
                           spellcheck="false"
                           aria-label="<?= $escaper->escapeHtmlAttr(__('Search the store')) ?>"
                           placeholder="<?= $escaper->escapeHtmlAttr(__('Search for products, categories, brands...')) ?>"/>
                    <svg class="psac-icon-search" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M10.5 18a7.5 7.5 0 100-15 7.5 7.5 0 000 15z"/>
                    </svg>
                    <button type="button" class="psac-clear" data-psac-clear hidden aria-label="<?= $escaper->escapeHtmlAttr(__('Clear')) ?>">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
                    </button>
                    <button type="submit" class="psac-submit" aria-label="<?= $escaper->escapeHtmlAttr(__('Search')) ?>">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 21l-4.35-4.35M10.5 18a7.5 7.5 0 100-15 7.5 7.5 0 000 15z"/></svg>
                        <?= $escaper->escapeHtml(__('Search')) ?>
                    </button>
                    <div class="psac-loading" data-psac-loading hidden></div>
                </form>
                <div class="psac-dropdown" data-psac-dropdown hidden role="listbox"></div>
            </div>
        </div>
    </div>
</div>

<script src="<?= $escaper->escapeUrl($block->getViewFileUrl('Panth_SearchAutocomplete::js/autocomplete.js')) ?>" defer></script>
<script src="<?= $escaper->escapeUrl($block->getViewFileUrl('Panth_SearchAutocomplete::js/attach-to-themecustomizer.js')) ?>" defer></script>
